{
  "name": "boards",
  "version": "0.1.10",
  "tablePrefix": "brd_",
  "description": "A discussion forum. Boards, sub-boards, threads and replies for registered users, with moderation, polls, subscriptions and email digests.",
  "publicBasePath": "boards",
  "permissions": [
    "boards.access",
    "boards.manage",
    "boards.moderate"
  ],
  "navGroupLabel": "Boards",
  "navEntries": [
    {
      "label": "Threads",
      "path": "/m/boards/threads",
      "icon": "<path d=\"M4 4h16v12H8l-4 4z\"/><path d=\"M8 9h8M8 12h5\"/>",
      "permission": "boards.access"
    },
    {
      "label": "Structure",
      "path": "/m/boards/structure",
      "icon": "<rect x=\"3\" y=\"3\" width=\"7\" height=\"7\"/><rect x=\"14\" y=\"3\" width=\"7\" height=\"7\"/><rect x=\"14\" y=\"14\" width=\"7\" height=\"7\"/><rect x=\"3\" y=\"14\" width=\"7\" height=\"7\"/>",
      "permission": "boards.access"
    },
    {
      "label": "Moderation",
      "path": "/m/boards/moderation",
      "icon": "<path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z\"/>",
      "permission": "boards.access"
    },
    {
      "label": "Analytics",
      "path": "/m/boards/analytics",
      "icon": "<path d=\"M18 20V10\"/><path d=\"M12 20V4\"/><path d=\"M6 20v-6\"/>",
      "permission": "boards.access"
    }
  ],
  "requiredEnvVars": [],
  "cookieCategories": [
    "functional"
  ],
  "teardown": [
    "brd_thread_tags",
    "brd_thread_views",
    "brd_post_reactions",
    "brd_poll_votes",
    "brd_poll_options",
    "brd_polls",
    "brd_post_revisions",
    "brd_reports",
    "brd_moderation_log",
    "brd_moderation_queue",
    "brd_read_state",
    "brd_bookmarks",
    "brd_drafts",
    "brd_posts",
    "brd_thread_subscriptions",
    "brd_board_subscriptions",
    "brd_threads",
    "brd_tags",
    "brd_sub_boards",
    "brd_boards",
    "brd_categories",
    "brd_bans",
    "brd_ip_bans",
    "brd_notification_prefs",
    "brd_user_profiles",
    "brd_thread_templates",
    "brd_import_jobs",
    "brd_settings"
  ],
  "cronJobs": [
    {
      "path": "/api/m/boards/cron/digest",
      "schedule": "0 7 * * *"
    }
  ],
  "puckBlocks": [
    {
      "type": "BoardHeader",
      "import": "./components/puck/BoardHeaderBlock",
      "rscImport": "./components/puck/BoardHeaderBlock.rsc",
      "component": "boardHeaderPuckComponent",
      "rscComponent": "boardHeaderPuckRscComponent",
      "layoutTypes": [
        "boardsCategory"
      ]
    },
    {
      "type": "SubBoardList",
      "import": "./components/puck/SubBoardListBlock",
      "component": "subBoardListPuckComponent",
      "rscComponent": "subBoardListPuckRscComponent",
      "layoutTypes": [
        "boardsCategory"
      ]
    },
    {
      "type": "ThreadList",
      "import": "./components/puck/ThreadListBlock",
      "rscImport": "./components/puck/ThreadListBlock.rsc",
      "component": "threadListPuckComponent",
      "rscComponent": "threadListPuckRscComponent",
      "layoutTypes": [
        "boardsCategory"
      ]
    },
    {
      "type": "ThreadHeader",
      "import": "./components/puck/ThreadHeaderBlock",
      "rscImport": "./components/puck/ThreadHeaderBlock.rsc",
      "component": "threadHeaderPuckComponent",
      "rscComponent": "threadHeaderPuckRscComponent",
      "layoutTypes": [
        "boardsEntry"
      ]
    },
    {
      "type": "ThreadBody",
      "import": "./components/puck/ThreadBodyBlock",
      "rscImport": "./components/puck/ThreadBodyBlock.rsc",
      "component": "threadBodyPuckComponent",
      "rscComponent": "threadBodyPuckRscComponent",
      "layoutTypes": [
        "boardsEntry"
      ]
    },
    {
      "type": "ReplyList",
      "import": "./components/puck/ReplyListBlock",
      "rscImport": "./components/puck/ReplyListBlock.rsc",
      "component": "replyListPuckComponent",
      "rscComponent": "replyListPuckRscComponent",
      "layoutTypes": [
        "boardsEntry"
      ]
    }
  ],
  "layoutTypes": {
    "groupLabel": "Boards",
    "types": [
      {
        "key": "boardsCategory",
        "label": "Board",
        "starterImport": "./lib/starterLayouts",
        "starterExport": "boardsCategoryStarters"
      },
      {
        "key": "boardsEntry",
        "label": "Thread",
        "starterImport": "./lib/starterLayouts",
        "starterExport": "boardsEntryStarters"
      }
    ]
  },
  "settingsTabs": [
    {
      "id": "boards",
      "label": "Boards",
      "permission": "boards.manage",
      "import": "./components/admin/BoardsSettingsTab",
      "component": "BoardsSettingsTab"
    }
  ],
  "extensionPoints": [
    {
      "point": "core.admin-dashboard-widgets",
      "id": "boards-summary",
      "permission": "boards.access",
      "import": "./components/admin/DashboardWidget",
      "component": "boardsDashboardWidget"
    },
    {
      "point": "core.menu-entity-provider",
      "id": "boards",
      "import": "./lib/menu-entity-provider",
      "component": "boardsMenuEntityProvider"
    },
    {
      "point": "core.media-usage-providers",
      "id": "boards",
      "import": "./lib/media-usage-provider",
      "component": "boardsMediaUsageProvider"
    }
  ],
  "requiresModules": []
}
