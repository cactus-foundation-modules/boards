    {
      "label": "Threads",
      "path": "/m/boards/threads",
      "icon": "<path d=\"M4 4h16v12H8l-4 4z\"/><path d=\"M8 9h8M8 12h5\"/>",
      "permission": "boards.access"
    },
    {
      "label": "Structure",
      "path": "/m/boards/structure",
      "icon": "<rect x=\"3\" y=\"3\" width=\"7\" height=\"7\"/><rect x=\"14\" y=\"3\" width=\"7\" height=\"7\"/><rect x=\"14\" y=\"14\" width=\"7\" height=\"7\"/><rect x=\"3\" y=\"14\" width=\"7\" height=\"7\"/>",
      "permission": "boards.access"
    },
    {
      "label": "Moderation",
      "path": "/m/boards/moderation",
      "icon": "<path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z\"/>",
      "permission": "boards.access"
    },
    {
      "label": "Analytics",
      "path": "/m/boards/analytics",
      "icon": "<path d=\"M18 20V10\"/><path d=\"M12 20V4\"/><path d=\"M6 20v-6\"/>",
      "permission": "boards.access"
    }
  ],
  "requiredEnvVars": [],
  "cookieCategories": ["functional"],
  "teardown": [
    "brd_thread_tags", "brd_thread_views", "brd_post_reactions",
    "brd_poll_votes", "brd_poll_options", "brd_polls",
    "brd_post_revisions", "brd_reports", "brd_moderation_log",
    "brd_moderation_queue", "brd_read_state", "brd_bookmarks",
    "brd_drafts", "brd_posts", "brd_thread_subscriptions",
    "brd_board_subscriptions", "brd_threads", "brd_tags",
    "brd_sub_boards", "brd_boards", "brd_categories",
    "brd_bans", "brd_ip_bans", "brd_notification_prefs",
    "brd_user_profiles", "brd_thread_templates", "brd_import_jobs",
    "brd_settings"
  ],
  "cronJobs": [
    { "path": "/api/m/boards/cron/digest", "schedule": "0 7 * * *" }
  ],
  "puckBlocks": [],
